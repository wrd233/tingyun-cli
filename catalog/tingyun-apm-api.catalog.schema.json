{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "catalog_version", "endpoints"],
  "properties": {
    "schema_version": {"const": "ty-apm.catalog.v1"},
    "catalog_version": {"type": "string"},
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "domain", "title", "method", "path", "safety", "execution_supported", "request", "response", "evidence", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "domain": {"type": "string"},
          "title": {"type": "string"},
          "method": {"enum": ["GET", "POST", "PUT", "DELETE", "UNKNOWN"]},
          "path": {"type": "string"},
          "safety": {"enum": ["read", "write", "guarded", "unknown"]},
          "execution_supported": {"type": "boolean"}
        }
      }
    }
  }
}
