{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tingyun/system-model-snapshot.schema.json",
  "title": "Tingyun Evidence-backed System Model Snapshot v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "model_version", "kind", "snapshot_id", "as_of", "freshness_threshold_seconds", "source_manifest_sha256", "source_runs", "entities", "relations", "coverage", "conflicts", "boundaries"],
  "properties": {
    "schema_version": {"const": 1},
    "model_version": {"const": "v0"},
    "kind": {"const": "evidence_backed_living_system_model"},
    "snapshot_id": {"type": "string", "minLength": 1},
    "as_of": {"type": "string", "minLength": 1},
    "freshness_threshold_seconds": {"type": "integer"},
    "source_manifest_sha256": {"type": "string", "minLength": 1},
    "source_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["run_id", "run_type", "overall", "manifest_sha256", "time_context"],
        "properties": {
          "run_id": {"type": "string", "minLength": 1},
          "manifest_sha256": {"type": "string", "minLength": 1}
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity_id", "entity_type", "canonical_identity", "display_identity", "evidence_refs", "time_contexts", "observations", "first_observed", "last_observed", "verification_level", "freshness", "coverage", "conflicts"],
        "properties": {
          "entity_id": {"type": "string", "minLength": 1},
          "entity_type": {"type": "string", "minLength": 1},
          "canonical_identity": {"type": "object"},
          "display_identity": {"type": "object"},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["run_id", "artifact_path", "raw_refs"],
              "properties": {
                "run_id": {"type": "string", "minLength": 1},
                "artifact_path": {"type": "string", "minLength": 1},
                "raw_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
                "item_ref": {"type": "string", "minLength": 1}
              }
            }
          },
          "time_contexts": {"type": "array", "items": {"type": "object"}},
          "observations": {"type": "array", "items": {"type": "object"}},
          "verification_level": {"enum": ["RUNTIME_VALIDATED"]},
          "freshness": {"enum": ["CURRENT", "STALE", "UNKNOWN"]},
          "coverage": {"enum": ["OBSERVED"]},
          "conflicts": {"type": "array"}
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relation_id", "relation_type", "from_entity_id", "to_entity_id", "time_semantics", "evidence_refs", "time_contexts", "observations", "time_context", "verification_level", "coverage"],
        "properties": {
          "relation_id": {"type": "string", "minLength": 1},
          "relation_type": {"type": "string", "minLength": 1},
          "from_entity_id": {"type": "string", "minLength": 1},
          "to_entity_id": {"type": "string", "minLength": 1},
          "time_semantics": {"enum": ["STABLE_OWNERSHIP_OBSERVATION", "WINDOWED_RUNTIME_OBSERVATION"]},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["run_id", "artifact_path", "raw_refs"],
              "properties": {
                "run_id": {"type": "string", "minLength": 1},
                "artifact_path": {"type": "string", "minLength": 1},
                "raw_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
                "item_ref": {"type": "string", "minLength": 1}
              }
            }
          },
          "time_contexts": {"type": "array", "items": {"type": "object"}},
          "observations": {"type": "array", "items": {"type": "object"}},
          "time_context": {"type": "object"},
          "verification_level": {"enum": ["RUNTIME_VALIDATED"]},
          "coverage": {"enum": ["OBSERVED"]}
        }
      }
    },
    "coverage": {"type": "object"},
    "conflicts": {"type": "array"},
    "boundaries": {
      "type": "object",
      "required": ["http_requests", "llm_calls", "generates_rca", "generates_report", "infers_identity_from_name_or_ip"],
      "properties": {
        "http_requests": {"const": 0},
        "llm_calls": {"const": 0},
        "generates_rca": {"const": false},
        "generates_report": {"const": false},
        "infers_identity_from_name_or_ip": {"const": false}
      }
    }
  }
}
